# Rocq build artifacts (theories/ and its role subdirectories)
theories/**/*.vo
theories/**/*.vok
theories/**/*.vos
theories/**/*.glob
theories/**/.*.aux
CoqMakefile
CoqMakefile.conf
# coq_makefile / `rocq makefile` default output name (used by the rocq MCP
# tooling and a bare `coq_makefile` invocation); the project Makefile uses
# CoqMakefile (see Makefile: COQMAKE=CoqMakefile) but guard the default too so
# tool-generated copies never get committed.
Makefile.coq
Makefile.coq.conf
.Makefile.coq.d
.lia.cache

# Extraction output (regenerated by `make proofs` from theories/Extract.v).
# Keep only the hand-written glue + dune files.
extracted/*.ml
extracted/*.mli
!extracted/glue.ml
!extracted/corpus_test.ml
!extracted/codec.ml
!extracted/nftc.ml
!extracted/nftc.mli
!extracted/example.ml
!extracted/semtest.ml
# .nft frontend (TODO 9): hand-written lexer/parser/lowering/driver + harness.
# (lexer.mll / parser.mly are not matched by the *.ml(i) ignore, but listed for
# clarity; their generated .ml live only under _build.)
!extracted/lexer.mll
!extracted/parser.mly
!extracted/nft_ast.ml
!extracted/nft_lower.ml
!extracted/nft_parse.ml
!extracted/nft_emit.ml
!extracted/nft2coq.ml
!extracted/parse_test.ml
extracted/_build/
.CoqMakefile.d
