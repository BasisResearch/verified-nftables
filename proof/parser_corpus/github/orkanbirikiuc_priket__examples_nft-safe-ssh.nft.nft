flush ruleset

table inet priket {
    chain input {
        type filter hook input priority 0; policy drop;
        iif "lo" accept comment "priket: allow loopback"
        ct state established,related accept comment "priket: allow established traffic"
        tcp dport 22 accept comment "Priket safe SSH access"
    }

    chain forward {
        type filter hook forward priority 0; policy drop;
    }

    chain output {
        type filter hook output priority 0; policy accept;
    }
}